{
  "name": "@swap-kit/cli",
  "version": "0.1.6",
  "description": "CLI for SwapKit — get DeFi quotes and simulate MEV from your terminal",
  "main": "./dist/index.js",
  "bin": {
    "swap-kit": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node ./dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "defi",
    "swap",
    "cli",
    "uniswap",
    "1inch",
    "mev"
  ],
  "author": "prazwal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prazwal/swap-kit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@swap-kit/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.0.1",
    "viem": "^2.23.2"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
